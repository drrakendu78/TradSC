// Overlay cargo natif (Slint) — design porté depuis l'artefact AIDesigner.
// Glass zinc-950 + amber #F59E0B + emerald néon #10E38B, chiffres mono.
// MANIFESTE : la card affiche TOUT ce qui est transporté. 1 marchandise → vue
// riche (top-3 reventes) ; 2+ → liste compacte (marchandise + meilleure revente).
// Focus-safe + clic-traversant gérés côté Rust (Win32 ex-styles).

struct SellLoc {
    rank: int,
    terminal: string,
    price: string,      // "35.00 aUEC/cSCU"
    eta: string,        // "~5 min" (vide si inconnu)
    profit: string,     // "+254 200"
    percent: string,    // "57%"
    positive: bool,
}

struct ManiEntry {
    commodity: string,
    guid: string,       // identifiant (pour marquer "vendu")
    color-index: int,   // index dans la palette (couleur par marchandise)
    sub: string,        // "200 SCU · 445 896 aUEC"
    shop: string,
    locations: [SellLoc],
}

export component CargoOverlay inherits Window {
    title: "StarTrad Cargo Overlay";
    no-frame: true;
    always-on-top: true;
    background: transparent;
    default-font-family: "Segoe UI";

    width: 340px;
    height: root.win-height;

    in property <[ManiEntry]> entries: [];
    in property <bool> pinned: false;
    // Mode édition : la card devient cliquable (côté Rust) + affiche les cases "vendu".
    in property <bool> editing: false;
    // Hauteur pilotée par Rust (grandit selon le manifeste → la fenêtre grandit
    // vers le bas, le coin haut ne bouge pas). 300 = vue riche 1 marchandise.
    in property <length> win-height: 300px;

    callback close();
    callback toggle-pin();
    callback mark-sold(string); // guid de la marchandise vendue

    // ── Palette (AIDesigner) ───────────────────────────────────────────
    out property <string> mono:    "Consolas";
    out property <color> amber:    #f59e0b;
    out property <color> emerald:  #10e38b;
    out property <color> white-:   #fafafa;
    out property <color> z200:     #e4e4e7;
    out property <color> z300:     #d4d4d8;
    out property <color> z400:     #a1a1aa;
    out property <color> z500:     #71717a;
    out property <color> z600:     #52525b;
    out property <color> hairline: #ffffff0d;
    // Palette SÉMANTIQUE (index choisi côté Rust selon nom/catégorie de la marchandise).
    out property <[color]> palette: [
        #fbbf24,  // 0 défaut / minerai
        #22d3ee,  // 1 gaz / halogène
        #cbd5e1,  // 2 métal / alliage (argent)
        #c084fc,  // 3 laranite (violet)
        #4ade80,  // 4 quantanium (vert radioactif)
        #fb923c,  // 5 cuivre / carburant (orange)
        #2dd4bf,  // 6 agricium / médical (teal)
        #fb7185,  // 7 vice (rose)
        #84cc16,  // 8 nourriture (vert)
        #7dd3fc,  // 9 diamant / quartz / minéral (glacé)
        #fcd34d,  // 10 or (doré)
        #9ca3af,  // 11 scrap / déchets (gris)
        #e879f9,  // 12 drogue (magenta)
        #60a5fa,  // 13 man-made (bleu acier)
    ];

    Rectangle {
        x: 6px; y: 6px;
        width: parent.width - 12px;
        height: parent.height - 12px;
        border-radius: 12px;
        clip: true;
        background: @linear-gradient(135deg, #101013 0%, #09090b 100%);
        border-width: 1px;
        border-color: root.hairline;
        drop-shadow-blur: 22px;
        drop-shadow-offset-y: 8px;
        drop-shadow-color: #000000e0;

        // Liseré clair en haut
        Rectangle {
            x: 1px; y: 1px; width: parent.width - 2px; height: 1px;
            background: #ffffff0d;
        }
        // Accent ambre à gauche + glow
        Rectangle {
            x: 0; y: 0; width: 3px; height: parent.height;
            background: root.amber;
            drop-shadow-blur: 12px;
            drop-shadow-color: #f59e0b99;
        }

        VerticalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 14px;
            padding-bottom: 14px;
            spacing: 0px;

            // ── Header ──────────────────────────────────────────────
            HorizontalLayout {
                height: 18px;
                alignment: space-between;
                HorizontalLayout {
                    spacing: 9px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 6px; height: 6px; border-radius: 3px;
                            background: root.amber;
                            drop-shadow-blur: 6px;
                            drop-shadow-color: root.amber;
                            opacity: 1.0;
                            animate opacity {
                                duration: 1300ms; iteration-count: -1;
                                easing: ease-in-out; direction: alternate;
                            }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: root.editing
                                ? "MODE VENTE"
                                : (root.entries.length > 1 ? "MANIFESTE" : "CARGO ACHETÉ");
                            color: root.editing ? root.emerald : root.z400;
                            font-size: 9px;
                            font-weight: 700;
                            letter-spacing: 2.4px;
                        }
                    }
                }
                // Checkmark dessiné (Path) = "achat confirmé".
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 16px; height: 16px; border-radius: 8px;
                        background: #f59e0b1f;
                        Path {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: 10px; height: 8px;
                            viewbox-width: 12; viewbox-height: 10;
                            stroke: #f59e0be6;
                            stroke-width: 1.7px;
                            commands: "M 1.5 5.5 L 4.5 8.5 L 10.5 1.5";
                        }
                    }
                }
            }

            Rectangle { height: 12px; }

            // ══ VUE RICHE : 1 seule marchandise (top-3 reventes) ══════
            if root.entries.length == 1 : VerticalLayout {
                spacing: 0px;
                property <ManiEntry> e: root.entries[0];

                VerticalLayout {
                    spacing: 2px;
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: space-between;
                        Text {
                            text: e.commodity;
                            color: root.palette[e.color-index];
                            font-size: 15px;
                            font-weight: 700;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                        // Bouton VENDU (mode édition) — clair, pas un carré cryptique
                        if root.editing : Rectangle {
                            width: 74px;
                            height: 22px;
                            border-radius: 11px;
                            border-width: 1px;
                            border-color: root.emerald;
                            background: #10e38b26;
                            HorizontalLayout {
                                padding-left: 9px;
                                padding-right: 10px;
                                spacing: 5px;
                                alignment: center;
                                VerticalLayout {
                                    alignment: center;
                                    Path {
                                        width: 10px; height: 10px;
                                        viewbox-width: 9; viewbox-height: 9;
                                        stroke: root.emerald;
                                        stroke-width: 1.7px;
                                        commands: "M 1.5 5 L 4 7.5 L 8 1.5";
                                    }
                                }
                                Text {
                                    text: "VENDU";
                                    color: root.emerald;
                                    font-size: 9px;
                                    font-weight: 700;
                                    letter-spacing: 0.8px;
                                    vertical-alignment: center;
                                }
                            }
                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { root.mark-sold(e.guid); }
                            }
                        }
                    }
                    Text {
                        text: e.sub;
                        color: root.z400;
                        font-size: 11px;
                        font-family: root.mono;
                    }
                    if e.shop != "" : Text {
                        text: e.shop;
                        color: root.z600;
                        font-size: 9px;
                        font-family: root.mono;
                        overflow: elide;
                    }
                }

                Rectangle { height: 14px; }
                Rectangle {
                    height: 1px;
                    background: @linear-gradient(90deg, #ffffff1a 0%, #ffffff08 50%, #ffffff00 100%);
                }
                Rectangle { height: 11px; }

                Text {
                    text: "MEILLEURES REVENTES";
                    color: root.z500;
                    font-size: 9px;
                    font-weight: 600;
                    letter-spacing: 1.6px;
                }
                Rectangle { height: 8px; }

                VerticalLayout {
                    spacing: 5px;
                    for loc in e.locations : Rectangle {
                        height: 36px;
                        border-radius: 8px;
                        background: loc.rank == 1 ? #ffffff0a : transparent;
                        border-width: 1px;
                        border-color: loc.rank == 1 ? #ffffff10 : #00000000;
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 9px;
                            spacing: 9px;
                            alignment: space-between;
                            HorizontalLayout {
                                spacing: 9px;
                                alignment: start;
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 22px; height: 22px;
                                        border-radius: 6px;
                                        background: loc.rank == 1 ? #18181b : #18181bcc;
                                        border-width: 1px;
                                        border-color: loc.rank == 1 ? #10e38b59 : #ffffff14;
                                        drop-shadow-blur: loc.rank == 1 ? 8px : 0px;
                                        drop-shadow-color: #10e38b3d;
                                        Text {
                                            text: loc.rank + "";
                                            color: loc.rank == 1 ? root.emerald : root.z400;
                                            font-size: 11px;
                                            font-weight: 600;
                                            font-family: root.mono;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 1px;
                                    Text {
                                        text: loc.terminal;
                                        color: loc.rank == 1 ? root.emerald : root.z300;
                                        font-size: 12px;
                                        font-weight: loc.rank == 1 ? 600 : 500;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: loc.eta != "" ? loc.price + "  ·  " + loc.eta : loc.price;
                                        color: root.z500;
                                        font-size: 9px;
                                        font-family: root.mono;
                                    }
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                spacing: 1px;
                                Text {
                                    text: loc.profit;
                                    color: loc.positive ? root.emerald : #fb7185;
                                    font-size: 13px;
                                    font-weight: 600;
                                    font-family: root.mono;
                                    horizontal-alignment: right;
                                }
                                Text {
                                    text: loc.percent;
                                    color: loc.positive ? #10e38b99 : #fb718599;
                                    font-size: 9px;
                                    font-family: root.mono;
                                    horizontal-alignment: right;
                                }
                            }
                        }
                    }
                }
            }

            // ══ VUE LISTE : 2+ marchandises, top-3 reventes en 1 LIGNE chacune ══
            if root.entries.length > 1 : VerticalLayout {
                spacing: 10px;
                for e in root.entries : VerticalLayout {
                    spacing: 3px;
                    // En-tête : nom ··· (SCU·aUEC en passif | bouton VENDU en édition)
                    HorizontalLayout {
                        alignment: space-between;
                        spacing: 7px;
                        Text {
                            text: e.commodity;
                            color: root.palette[e.color-index];
                            font-size: 13px;
                            font-weight: 700;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                        if !root.editing : Text {
                            text: e.sub;
                            color: root.z500;
                            font-size: 9px;
                            font-family: root.mono;
                            vertical-alignment: center;
                        }
                        if root.editing : Rectangle {
                            width: 66px;
                            height: 19px;
                            border-radius: 10px;
                            border-width: 1px;
                            border-color: root.emerald;
                            background: #10e38b26;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 9px;
                                spacing: 5px;
                                alignment: center;
                                VerticalLayout {
                                    alignment: center;
                                    Path {
                                        width: 9px; height: 9px;
                                        viewbox-width: 9; viewbox-height: 9;
                                        stroke: root.emerald;
                                        stroke-width: 1.7px;
                                        commands: "M 1.5 5 L 4 7.5 L 8 1.5";
                                    }
                                }
                                Text {
                                    text: "VENDU";
                                    color: root.emerald;
                                    font-size: 8px;
                                    font-weight: 700;
                                    letter-spacing: 0.8px;
                                    vertical-alignment: center;
                                }
                            }
                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { root.mark-sold(e.guid); }
                            }
                        }
                    }
                    // Top-3 reventes — 1 ligne : terminal · (profit + ETA)
                    VerticalLayout {
                        spacing: 2px;
                        for loc in e.locations : Rectangle {
                            height: 19px;
                            border-radius: 5px;
                            background: loc.rank == 1 ? #ffffff0a : transparent;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 6px;
                                alignment: space-between;
                                Text {
                                    text: (loc.rank == 1 ? "● " : "") + loc.terminal;
                                    color: loc.rank == 1 ? root.emerald : root.z400;
                                    font-size: 10px;
                                    font-weight: loc.rank == 1 ? 600 : 400;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }
                                HorizontalLayout {
                                    spacing: 7px;
                                    alignment: end;
                                    Text {
                                        text: loc.profit;
                                        color: loc.positive ? root.emerald : #fb7185;
                                        font-size: 10px;
                                        font-weight: 600;
                                        font-family: root.mono;
                                        vertical-alignment: center;
                                    }
                                    if loc.eta != "" : Text {
                                        text: loc.eta;
                                        color: root.z500;
                                        font-size: 9px;
                                        font-family: root.mono;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── Mini-contrôle [pin][cacher][✕] ──────────────────────────────────────
// Fenêtre SÉPARÉE de la card : NOACTIVATE (ne vole pas le focus) mais PAS
// click-through → ses boutons sont cliquables. Icônes DESSINÉES (Path).
export component CargoControl inherits Window {
    title: "StarTrad Cargo Overlay Control";
    no-frame: true;
    always-on-top: true;
    background: transparent;
    default-font-family: "Segoe UI";
    width: 108px;
    height: 26px;

    in property <bool> pinned: false;
    in property <bool> hidden: false;
    in property <bool> editing: false;
    callback close();
    callback toggle-pin();
    callback toggle-hide();
    callback toggle-edit();

    out property <color> amber: #f59e0b;

    Rectangle {
        background: @linear-gradient(180deg, #1d1d21 0%, #141417 100%);
        border-radius: 13px;
        border-width: 1px;
        border-color: #ffffff24;

        HorizontalLayout {
            padding: 5px;
            spacing: 3px;

            // PIN (toggle)
            pin-btn := Rectangle {
                width: 22px;
                border-radius: 7px;
                background: pin-ta.has-hover ? #ffffff14 : transparent;
                pin-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => { root.toggle-pin(); }
                    Rectangle {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 11px;
                        height: 11px;
                        border-radius: 5.5px;
                        background: root.pinned ? root.amber : transparent;
                        border-width: 1.5px;
                        border-color: root.pinned ? root.amber : #8a8a90;
                        drop-shadow-blur: root.pinned ? 7px : 0px;
                        drop-shadow-color: root.amber;
                    }
                }
            }

            // CACHER : chevron bas ↔ haut
            hide-btn := Rectangle {
                width: 22px;
                border-radius: 7px;
                background: hide-ta.has-hover ? #ffffff14 : transparent;
                hide-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => { root.toggle-hide(); }
                    Path {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 11px;
                        height: 8px;
                        viewbox-width: 11;
                        viewbox-height: 8;
                        stroke: hide-ta.has-hover ? #e4e4e7 : #b4b4ba;
                        stroke-width: 1.5px;
                        commands: root.hidden
                            ? "M 1.5 6 L 5.5 2 L 9.5 6"
                            : "M 1.5 2.5 L 5.5 6.5 L 9.5 2.5";
                    }
                }
            }

            // ÉDITER : active le mode "vendu" (rend la card cliquable + affiche les cases)
            edit-btn := Rectangle {
                width: 22px;
                border-radius: 7px;
                background: root.editing ? #10e38b2e : (edit-ta.has-hover ? #ffffff14 : transparent);
                edit-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => { root.toggle-edit(); }
                    Rectangle {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 13px;
                        height: 13px;
                        border-radius: 3px;
                        border-width: 1.5px;
                        border-color: root.editing ? #10e38b : #b4b4ba;
                        Path {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: 8px;
                            height: 8px;
                            viewbox-width: 9;
                            viewbox-height: 9;
                            stroke: root.editing ? #10e38b : #b4b4ba;
                            stroke-width: 1.5px;
                            commands: "M 1.5 5 L 4 7.5 L 8 1.5";
                        }
                    }
                }
            }

            // CLOSE : ✕ dessiné
            close-btn := Rectangle {
                width: 22px;
                border-radius: 7px;
                background: close-ta.has-hover ? #ef444438 : transparent;
                close-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => { root.close(); }
                    Path {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 10px;
                        height: 10px;
                        viewbox-width: 10;
                        viewbox-height: 10;
                        stroke: close-ta.has-hover ? #fca5a5 : #b4b4ba;
                        stroke-width: 1.5px;
                        commands: "M 1.5 1.5 L 8.5 8.5 M 8.5 1.5 L 1.5 8.5";
                    }
                }
            }
        }
    }
}
