{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "overlay",
  "description": "Capability for overlay and external webview windows",
  "windows": ["overlay_*", "wvoverlay_*", "overlayctl_*", "crafter_*", "uexcorp_*", "custom_*"],
  "remote": {
    "urls": ["https://*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:window:allow-set-focus",
    "core:window:allow-inner-size",
    "core:event:default"
  ]
}
